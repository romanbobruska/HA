    {
        "id": "pool_decide_func",
        "type": "function",
        "z": "f1e2d3c4b5a60002",
        "g": "pool_g_decide",
        "name": "POOL rozhodovac (§11)",
        "func": "// POOL Heating — hlavni rozhodovac (§11)\n// Volá se každých 60s z data collect.\n// Outputs:\n//   1 -> patrony akce (pole {action: \"p1_on\"/\"p1_off\"/...})\n//   2 -> ventil akce ({action: \"ventil_on\"/\"ventil_off\"})\n//   3 -> filtrace lock timestamp ({payload: ms})\n//   4 -> NIBE akce (STUB v B2, aktivni v B3)\n//   5 -> topeni_mod sync ({payload: \"BAZÉN - Patrony\"/\"Vypnuto\"/...})\n\nconst cfg = global.get(\"fve_config\") || {};\n\n// ===== HELPERY =====\nfunction getState(id) {\n    return global.get(\"homeassistant.homeAssistant.states['\" + id + \"']\");\n}\nfunction getFloat(id, def) {\n    const s = getState(id);\n    if (!s) return def;\n    const v = parseFloat(s.state);\n    return isNaN(v) ? def : v;\n}\nfunction getBool(id, def) {\n    const s = getState(id);\n    if (!s) return def;\n    return s.state === \"on\";\n}\nfunction isAvail(id) {\n    const s = getState(id);\n    return !!s && s.state !== \"unavailable\" && s.state !== \"unknown\";\n}\n\n// ===== HARD GUARD: letni_rezim + pool_enabled =====\nconst letniRezim = cfg.letni_rezim === true;\nconst poolEnabled = cfg.pool_enabled === true;\nif (!letniRezim || !poolEnabled) {\n    node.status({fill: \"grey\", shape: \"ring\",\n        text: \"OFF (letni=\" + (letniRezim?\"1\":\"0\") + \", enabled=\" + (poolEnabled?\"1\":\"0\") + \")\"});\n    // V teto chvili NESAHAME na nic (ani topeni_mod) — mohlo by to prepisovat\n    // mod nastaveny topenim domu v zimnim rezimu.\n    return [null, null, null, null, null];\n}\n\n// ===== CTENI STAVU =====\nconst teplotaVody     = getFloat(\"sensor.hp2551ae_pro_v2_1_0_temperature_1\", 20);\nconst teplotaNadrz    = getFloat(\"sensor.teplota_smesovac_teplota\", 20);\nconst cilovaVoda      = cfg.pool_cilova_teplota_vody || 28;\nconst minNadrz        = cfg.pool_min_teplota_nadrz || 30;\nconst maxNadrz        = cfg.pool_max_teplota_nadrz || 60;\nconst ventilStartC    = cfg.pool_ventil_start_c || 50;\nconst poolPatSocMin   = cfg.pool_patrony_soc_min || 90;\nconst minSolarPatron  = cfg.topeni_patron_min_solar_w || 5000;\nconst filtraceCoolMin = cfg.pool_filtrace_cooldown_min || 10;\n\nconst solarW = getFloat(\"sensor.vyroba_fve\", 0);\nconst soc    = getFloat(\"sensor.baterie_soc\", 0);\nconst autoMaHlad = getBool(\"input_boolean.auto_ma_hlad\", false);\n// TODO B3: bojler_natopen ma slozitejsi logiku (§11.5 bod 6 — vyjimka pri dostatecne vyrobe)\n// Zatim konzervativne: bojler_natopen se ignoruje, predpoklad OK.\nconst bojlerOk = true;\nconst filtraceAvail = isAvail(\"switch.filtrace\");\n\n// Aktualni stavy akcnich clenu\nconst p1on = getBool(\"switch.patrona_faze_1\", false);\nconst p2on = getBool(\"switch.patrona_faze_3_2\", false);\nconst p3on = getBool(\"switch.patrona_faze_3\", false);\nconst ventilOn = getBool(\"switch.bazen_ventil_smesovac\", false);\nconst activeFaze = (p1on?1:0) + (p2on?1:0) + (p3on?1:0);\n\n// ===== HELPER: prevod pozadovanych fazi na akce =====\nfunction makeFazeActions(desired) {\n    const acts = [];\n    // Patrony faze se spinaji postupne (p1 -> p1+p2 -> p1+p2+p3).\n    // Pro jednoduchost B2: binarni on/off podle desired countu.\n    const want = [desired >= 1, desired >= 2, desired >= 3];\n    const cur  = [p1on, p2on, p3on];\n    const names = [\"p1\", \"p2\", \"p3\"];\n    for (let i = 0; i < 3; i++) {\n        if (want[i] && !cur[i]) acts.push({action: names[i] + \"_on\"});\n        else if (!want[i] && cur[i]) acts.push({action: names[i] + \"_off\"});\n    }\n    return acts;\n}\n\n// ===== STROP BAZENU (§11.3): teplota vody ≥ cil → patrony OFF, cooldown filtrace 10 min =====\nif (teplotaVody >= cilovaVoda) {\n    const acts = makeFazeActions(0);\n    const ventAct = ventilOn ? {action: \"ventil_off\"} : null;\n    const lockUntil = Date.now() + filtraceCoolMin * 60000;\n    node.status({fill: \"green\", shape: \"dot\",\n        text: \"CIL voda=\" + teplotaVody.toFixed(1) + \"°C ≥ \" + cilovaVoda + \"°C → cooldown\"});\n    return [\n        acts.length > 0 ? acts : null,\n        ventAct,\n        {payload: lockUntil},\n        null,\n        {payload: \"Vypnuto\"}\n    ];\n}\n\n// ===== STROP NADRZE (§11.3): teplota nadrze ≥ max → patrony OFF (NIBE neresi) =====\nif (teplotaNadrz >= maxNadrz) {\n    const acts = makeFazeActions(0);\n    node.status({fill: \"red\", shape: \"dot\",\n        text: \"MAX NADRZ \" + teplotaNadrz.toFixed(1) + \"°C ≥ \" + maxNadrz + \"°C → patrony OFF\"});\n    return [acts.length > 0 ? acts : null, null, null, null, null];\n}\n\n// ===== PODMINKY POVOLENI PATRON (§11.5 + §11.7) =====\nconst autoOk  = !autoMaHlad;\nconst socOk   = soc >= poolPatSocMin;\nconst solarOk = solarW >= minSolarPatron;\n\nconst canRunPatrony = autoOk && socOk && solarOk && bojlerOk;\n\n// ===== PATRONY — MINIMAL korekce v B2 (plna smycka v B3) =====\n// V B2: pokud canRunPatrony → alespon 1 faze; pokud ne → 0 fazi.\n// V B3: nahradit plnou korekci smyckou z §8.5 (feedback na baterii, dead band).\nlet desiredFaze = activeFaze;\nlet patStatusTxt = \"\";\n\nif (canRunPatrony) {\n    if (activeFaze === 0) {\n        desiredFaze = 1;\n        patStatusTxt = \"START 1f\";\n    } else {\n        // TODO B3: korekce smycka dle bCh (nabijeni/vybijeni baterie)\n        desiredFaze = activeFaze;\n        patStatusTxt = \"HOLD \" + activeFaze + \"f\";\n    }\n} else {\n    desiredFaze = 0;\n    const reasons = [];\n    if (!autoOk) reasons.push(\"auto\");\n    if (!socOk) reasons.push(\"SOC<\" + poolPatSocMin);\n    if (!solarOk) reasons.push(\"solar<\" + minSolarPatron);\n    if (!bojlerOk) reasons.push(\"bojler\");\n    patStatusTxt = \"OFF (\" + reasons.join(\",\") + \")\";\n}\n\nconst patronyActions = makeFazeActions(desiredFaze);\n\n// ===== VENTIL HYSTEREZE (§11.3) =====\nlet ventilAction = null;  // null = beze zmeny\nif (ventilOn) {\n    if (teplotaNadrz < minNadrz) ventilAction = \"off\";\n} else {\n    if (teplotaNadrz >= ventilStartC) ventilAction = \"on\";\n}\n\n// VENTIL CAN-OPEN check (§11.5 bod 8): ventil ON vyzaduje dostupny switch.filtrace\n// Pokud filtrace unavailable, ventil zustava zavreny (topime jen nadrz, cekame).\nif (ventilAction === \"on\" && !filtraceAvail) {\n    ventilAction = null;  // zustava OFF\n    patStatusTxt += \" [vent↑blocked: filtr unavail]\";\n}\n\nlet ventilMsg = null;\nif (ventilAction === \"on\") ventilMsg = {action: \"ventil_on\"};\nelse if (ventilAction === \"off\") ventilMsg = {action: \"ventil_off\"};\n\n// ===== FILTRACE LOCK (§11.4) =====\n// Pokud ventil bude/je aktivne otevreny (topime do vymeniku), prodluz lock o 60s + cooldown.\nconst ventilActiveAfter = (ventilAction === \"on\") || (ventilOn && ventilAction !== \"off\");\nlet lockMsg = null;\nif (ventilActiveAfter) {\n    const lockUntil = Date.now() + 60000 + filtraceCoolMin * 60000;\n    lockMsg = {payload: lockUntil};\n}\n// TODO B3: NIBE→bazen taky musi prodluzovat lock\n\n// ===== TOPENI_MOD SYNC (§11.9) =====\nlet mod = \"Vypnuto\";\nconst patronyRunAfter = desiredFaze > 0;\nconst nibeRunAfter = false;  // TODO B3\nif (patronyRunAfter && nibeRunAfter) mod = \"BAZÉN - NIBE + Patrony\";\nelse if (patronyRunAfter) mod = \"BAZÉN - Patrony\";\nelse if (nibeRunAfter) mod = \"BAZÉN - NIBE\";\n\n// ===== STATUS =====\nnode.status({\n    fill: desiredFaze > 0 ? \"green\" : \"grey\",\n    shape: \"dot\",\n    text: patStatusTxt + \" voda=\" + teplotaVody.toFixed(1) + \"° nadrz=\" + teplotaNadrz.toFixed(1)\n          + \"° SOC=\" + soc.toFixed(0) + \"% vent=\" + (ventilOn?\"ON\":\"OFF\")\n});\n\nreturn [\n    patronyActions.length > 0 ? patronyActions : null,\n    ventilMsg,\n    lockMsg,\n    null,  // NIBE STUB (B3)\n    {payload: mod}\n];\n",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 270,
        "y": 250,
