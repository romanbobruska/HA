    {
        "id": "f8bbbf2eb77de391",
        "type": "function",
        "z": "0a2df88897520187",
        "g": "09797f9996ff875a",
        "name": "🧠 Rozhodovací logika",
        "func": "// 🧠 Rozhodovací logika bojleru — cílová teplota dle přebytku, ceny, forecastu\nvar TM=flow.get(\"TEPLOTA_MAX\")||69,TV=flow.get(\"TEPLOTA_VYSOKA\")||60,TS=flow.get(\"TEPLOTA_STREDNI\")||55;\nvar TMI=flow.get(\"TEPLOTA_MIN\")||20,TPS=flow.get(\"TEPLOTA_POVINNY_SOLAR\")||40;\nvar HY=flow.get(\"HYSTEREZE\")||500,SB=flow.get(\"SPOTREBA_BOJLER\")||2500;\nvar PLV=flow.get(\"PRICE_LEVEL_LEVNY\")||3,CKL=flow.get(\"CENA_KWH_LEVNA\")||2.6;\nvar FT=flow.get(\"FORECAST_THRESHOLD\")||35000;\nvar mxS=global.get(\"max_spotreba_sit\")||24000,fD=global.get(\"forecast_vyroba_dnes\")||0,fZ=global.get(\"forecast_vyroba_zitra\")||0;\nvar cerp=global.get(\"cerpadlo_topi\")===true;\nvar clE=global.get(\"homeassistant.homeAssistant.states['climate.smart_socket_thermostat_24090276694597600801c4e7ae0a2e53']\")||{};\nvar aktT=parseFloat((clE.attributes||{}).temperature)||0;\nvar cfg=global.get(\"fve_config\")||{},MG=cfg.max_spotreba_sit_w||22000,SM=cfg.safety_margin_w||2000,SL=MG-SM;\nvar dom=msg.jsme_doma===\"on\",rv=msg.rychle_voda===\"on\",tB=msg.teplota_bojleru||0;\nvar sBA=msg.spotreba_bojleru||0,bat=msg.battery_percent||0,rV=msg.rozdil_vyroby||0;\nvar let2=msg.letni_rezim===\"on\",aH=msg.auto_hlad===\"on\",aA=msg.auto_automatizace===\"on\";\nvar pL=msg.price_level||24,cK=msg.cena_kwh||10,cS=msg.celkova_spotreba||0,sSit=msg.spotreba_ze_site||0;\nvar hr=new Date().getHours(),mn=new Date().getMinutes(),cm=hr*60+mn;\nvar jPC=cm>=17*60&&cm<=19*60+30,bO=sBA>100,vK=SL-cS,mZ=bO||(vK>=SB);\nvar PZM=4000+SB+HY,PVM=4000,PZV=SB+HY,PVV=-HY;\nvar jLE=(pL<=PLV)||(cK<=CKL),sD=fD>FT,sDZ=fZ>FT;\nvar isZapNak=(global.get(\"fve_current_mode\")||\"\")===\"zaporna_nakupni_cena\";\nvar hasBoilerHR=(MG-sSit)>=SB;\nvar cT=TMI,dv=\"\";\nif(!dom){cT=TMI;dv=\"Není doma\";}\nelse if(rv){cT=TM;dv=\"Rychle voda\";}\nelse if(isZapNak&&hasBoilerHR){cT=TM;dv=\"Záporná! Volno:\"+Math.round(MG-sSit)+\"W\";}\nelse if(jPC&&tB<58){if(!mZ){cT=TMI;dv=\"Pov.čas limit sítě\";}\nelse if(sDZ&&tB>=TPS){cT=TPS;dv=\"Pov.čas zítra sol→\"+TPS+\"°C\";}\nelse if(sDZ){cT=TPS;dv=\"Pov.ohřev na \"+TPS+\"°C\";}\nelse{cT=TV;dv=\"Pov.ohřev 17-19:30\";}}\nelse if(cerp&&rV<PZV){cT=TMI;dv=\"NIBE přeb:\"+Math.round(rV/1000)+\"kW\";}\nelse if(bat>96){var pM=bO?PVM:PZM,pV=bO?PVV:PZV;\nif(rV>pM){cT=aH&&aA?TV:TM;dv=(aH?\"Přeb+auto\":\"Bat plné+přeb \")+(Math.round(rV/1000))+\"kW\";}\nelse if(rV>pV){cT=TV;dv=\"Přeb \"+Math.round(rV/1000)+\"kW\";}\nelse if(bO&&rV>-SB){cT=flow.get(\"posledni_cilova_teplota\")||TMI;dv=\"Hystereze \"+cT+\"°C\";}\nelse{if(!let2&&jLE&&mZ){cT=TS;dv=\"Levná L\"+pL;}else{cT=TMI;dv=let2?\"Léto čeká\":\"Drahá/málo\";}}}\nelse{var p5=bO?PVV:PZV,pM5=bO?PVM:PZM;\nif(rV>pM5){cT=TM;dv=\"Velký přeb \"+Math.round(rV/1000)+\"kW bat:\"+bat+\"%\";}\nelse if(rV>p5){cT=TV;dv=\"Přeb \"+Math.round(rV/1000)+\"kW bat:\"+bat+\"%\";}\nelse if(bO&&rV>-SB){cT=flow.get(\"posledni_cilova_teplota\")||TMI;dv=\"Hystereze \"+cT+\"°C\";}\nelse if(let2&&sD){cT=TMI;dv=\"Léto fc:\"+Math.round(fD/1000)+\"kWh\";}\nelse if(!let2&&jLE&&mZ){cT=TS;dv=\"Levná L\"+pL+\" \"+cK+\"Kč\";}\nelse{cT=TMI;dv=let2?\"Léto solar\":!mZ?\"Limit sítě\":\"Drahá\";}}\nflow.set(\"posledni_cilova_teplota\",cT);\nvar clSt=(clE||{}).state||\"unavailable\";\nif(clSt===\"unavailable\"){node.status({fill:\"red\",shape:\"ring\",text:\"Meross UNAVAIL\"});return null;}\nif(cT===aktT){node.status({fill:\"blue\",shape:\"dot\",text:cT+\"/\"+aktT+\"°C BEZ ZMĚNY \"+dv});return null;}\nmsg.payload={teplota:cT,duvod:dv,debug:{dom:dom,rv:rv,tB:tB,bat:bat,rV:rV,let2:let2,pL:pL,cK:cK,jLE:jLE,cS:cS,mZ:mZ}};\nvar b=\"grey\";if(cT>=TV)b=\"green\";else if(cT>=TS)b=\"yellow\";\nnode.status({fill:b,shape:bO?\"ring\":\"dot\",text:cT+\"°C \"+dv});\nreturn msg;",
