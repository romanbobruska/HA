    {
        "id": "7efc2560d20a0a05",
        "type": "function",
        "z": "0a2df88897520187",
        "g": "7d6c1cd0300cfd29",
        "name": "­čôŁ Nastav parametry",
        "func": "// ÔĽöÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽŚ\n// ÔĽĹ  KONFIGUROVATELN├ë PARAMETRY - UPRAV HODNOTY NÍŽE           ÔĽĹ\n// ÔĽÜÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽŁ\n\nconst CONFIG = {\n    // === TEPLOTY (┬░C) ===\n    TEPLOTA_MAX: 69,        // Maxim├íln├ş teplota bojleru\n    TEPLOTA_VYSOKA: 60,     // Vysok├í teplota (běžn├Ż oh┼Öev)\n    TEPLOTA_STREDNI: 58,    // St┼Öedn├ş teplota (levn├í elekt┼Öina)\n    TEPLOTA_MIN: 20,        // Minim├íln├ş teplota (vypnuto)\n    TEPLOTA_POVINNY_SOLAR: 40, // Teplota v povinn├Żch hodin├ích kdy┼ż z├ştra velk├Ż sol├ír\n    \n    // === HYSTEREZE A SPOT┼śEBA ===\n    HYSTEREZE: 500,         // Hystereze v W (zabra┼łuje oscilaci)\n    SPOTREBA_BOJLER: 2500,  // Spot┼Öeba bojleru v W\n    \n    // === CENOV├ë PRAHY ===\n    PRICE_LEVEL_LEVNY: 6,   // Level ceny (1-24), kdy je proud levn├Ż\n    CENA_KWH_LEVNA: 2.6,    // Cena v K─Ź/kWh, kdy je proud levn├Ż\n    \n    // === FORECAST ===\n    FORECAST_THRESHOLD: 35000  // Pr├íh forecastu v Wh (35kWh)\n};\n\n// ÔĽöÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽŚ\n// ÔĽĹ  ULO┼ŻEN├Ź DO FLOW PROM─ÜNN├ŁCH - NEM─ÜNIT                      ÔĽĹ\n// ÔĽÜÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽŁ\n\nfor (const [key, value] of Object.entries(CONFIG)) {\n    flow.set(key, value);\n}\n\nmsg.payload = {\n    status: \"Konfigurace ulo┼żena\",\n    config: CONFIG\n};\n\nnode.status({fill: \"green\", shape: \"dot\", text: \"Konfigurace ulo┼żena\"});\n//node.warn(\"Bojler konfigurace ulo┼żena: \" + JSON.stringify(CONFIG));\n\nreturn msg;",
