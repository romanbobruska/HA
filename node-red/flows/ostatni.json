    {
        "id": "lock_eval_func",
        "type": "function",
        "z": "58f453ee71c85d6d",
        "g": "314bb66109910b71",
        "name": "Vyhodnoť stav zámku",
        "func": "// Zamek hlavni dvere (Yale Linus L2) — rizeni pres MATTER (lokalni, bez cloudu).\n// Matter lock.unlock retrahuje JEN zavoru (deadbolt) — dvere zustanou zavrene (overeno testem 2026-06-11).\n// FAIL-CLOSED (tvrde spoustece): alarm armed NEBO nikdo doma + dvere zavrene -> lock.lock (ihned).\n// AUTO-UNLOCK: celkovy alarm armed -> disarmed -> lock.unlock (jen zavora) + grace okno.\n// NOCNI ZAMEK 21:00-07:00 (jsme doma, odemceno, dvere zavrene): akcni notifikace \"Zamknout?\".\n//   - bez reakce 30 min -> zamkne. \"Necham na sobe\" -> za 1 h se zepta znovu.\n// POZN.: manualni odemceni uz NENASTAVUJE grace (aby odchod/alarm zamkly) — grace jen po auto-unlock.\n// out1 = ZAMKNI (lock.lock), out2 = ODEMKNI (lock.unlock, Matter), out3 = AKCNI NOTIFIKACE\n\nvar LOCK_ID   = \"lock.chodba_hlavni_dvere\";\nvar DOOR_ID   = \"binary_sensor.chodba_hlavni_dvere_dvere\";\nvar CELK_ID   = \"alarm_control_panel.horousany_sekce_1_celkovy_alarm\";\nvar GARAZ_ID  = \"alarm_control_panel.horousany_sekce_7_garaz_alarm\";\nvar PERSON_ID = \"person.home_assitant\";\nvar HOME_ID   = \"input_boolean.jsme_doma\";\nvar NIGHT_FROM = 21, NIGHT_TO = 7;     // nocni okno pro akcni notifikaci\nvar COOLDOWN_MS = 10000;\nvar GRACE_MS = 3600000;                // 60 min po auto-odemceni (disarm) nezamykat\nvar ASK_TIMEOUT_MS = 180000;          // 3 min bez reakce -> zamkni\n\nfunction gS(id){ return (global.get(\"homeassistant.homeAssistant.states['\" + id + \"']\") || {}).state || \"\"; }\nfunction isArmed(x){ return x && x.indexOf(\"armed\") === 0; }\nfunction isLocked(st){ return st === \"locked\" || st === \"locking\"; }\nfunction isUnlocked(st){ return st === \"unlocked\" || st === \"unlocking\" || st === \"open\"; }\nfunction isDoorOpen(st){ return st === \"on\" || st === \"open\"; }\nfunction isDoorClosed(st){ return st === \"off\" || st === \"closed\"; }\nfunction g(k, def){ var v = global.get(\"lock_\" + k); if (v === undefined) v = flow.get(\"lock_\" + k); return (v === undefined || v === null) ? def : v; }\nfunction s(k, v){ global.set(\"lock_\" + k, v); flow.set(\"lock_\" + k, v); }\n\nvar celk = gS(CELK_ID);\nvar garaz = gS(GARAZ_ID);\nvar person = gS(PERSON_ID);\nvar homeB = gS(HOME_ID);\nvar lock = gS(LOCK_ID);\nvar door = gS(DOOR_ID);\nvar h = new Date().getHours();\nvar now = Date.now();\n\nif (!lock || lock === \"unavailable\" || lock === \"unknown\") {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"lock nedostupny: \" + (lock || \"?\") });\n    return null;\n}\n\nvar jeNoc = (h >= NIGHT_FROM || h < NIGHT_TO);\nvar nikdoDoma = (homeB === \"off\");   // jen autoritativni jsme_doma; person.* GPS flapuje -> falesne zamykani (Bug1)\nvar maBytZamceno = isArmed(celk) || isArmed(garaz) || nikdoDoma;   // TVRDE spoustece (noc resi notifikace)\nvar doorOpen = isDoorOpen(door);\nvar doorClosed = isDoorClosed(door);\n\nvar lastCmdAt = g(\"last_cmd_at\", 0);\nvar pending = g(\"pending_action\", null);\nvar lastObs = g(\"last_observed\", undefined);\n\nif (pending === \"lock\" && isLocked(lock)) { pending = null; s(\"pending_action\", null); }\nif (pending === \"unlock\" && isUnlocked(lock)) { pending = null; s(\"pending_action\", null); }\nif (lastObs !== undefined && lock !== lastObs && (now - lastCmdAt) > 5000) { pending = null; s(\"pending_action\", null); }\ns(\"last_observed\", lock);\n\nvar graceUntil = g(\"grace_until\", 0);\nif (now >= graceUntil) { graceUntil = 0; }\nvar graceActive = (graceUntil > 0 && now < graceUntil);\n\n// Hrana odkodovani celeho domu (armed -> disarmed) — detekce z UDALOSTI (old->new),\n// odolne vuci restartu NR i vypadku alarmu; unavailable->disarmed NEspousti odemceni (§20.3).\nvar ev = msg.data || {};\nvar evId = ev.entity_id || msg.topic || \"\";\nvar oldS = (ev.old_state && ev.old_state.state) || \"\";\nvar newS = (ev.new_state && ev.new_state.state) || \"\";\nfunction armish(x){ return isArmed(x) || x === \"disarming\" || x === \"arming\" || x === \"pending\" || x === \"triggered\"; }\nvar disarmEdge = (evId === CELK_ID && newS === \"disarmed\" && armish(oldS));\n\n// AUTO-ODEMKNUTI: vedomy ukon uzivatele -> odemkni zavoru (Matter) NEZAVISLE na cooldownu.\nif (disarmEdge) {\n    s(\"grace_until\", now + GRACE_MS);\n    if (!isUnlocked(lock) && pending !== \"unlock\") {\n        s(\"pending_action\", \"unlock\");\n        s(\"last_cmd_at\", now);\n        node.status({ fill: \"green\", shape: \"dot\", text: \"ODEMYKAM (odkodovan dum)\" });\n        return [null, msg, null];\n    }\n}\n\nif (now - lastCmdAt < COOLDOWN_MS) {\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"cooldown lock=\" + lock + \" door=\" + (door || \"?\") });\n    return null;\n}\n\n// FAIL-CLOSED zamykani (tvrde: alarm / nikdo doma)\nif (maBytZamceno && !isLocked(lock)) {\n    if (doorOpen) {\n        s(\"pending_action\", null);\n        node.status({ fill: \"red\", shape: \"ring\", text: \"ma byt zamceno, ale dvere otevrene\" });\n        return null;\n    }\n    if (!doorClosed && door !== \"\") {\n        s(\"pending_action\", null);\n        node.status({ fill: \"red\", shape: \"ring\", text: \"kontakt dveri nejisty: \" + door });\n        return null;\n    }\n    if (graceActive) {\n        node.status({ fill: \"blue\", shape: \"dot\", text: \"grace po odemceni \" + Math.round((graceUntil - now) / 60000) + \" min\" });\n        return null;\n    }\n    if (pending === \"lock\") { return null; }\n    s(\"pending_action\", \"lock\");\n    s(\"last_cmd_at\", now);\n    var duvod = (isArmed(celk) || isArmed(garaz)) ? \"alarm\" : \"nikdo doma\";\n    node.status({ fill: \"yellow\", shape: \"dot\", text: \"ZAMYKAM (\" + duvod + \") door=\" + (door || \"?\") });\n    return [msg, null, null];\n}\n\n// === NOCNI ZAMEK 21:00-07:00 (akcni notifikace, jen kdyz jsme doma) ===\nvar askAt = g(\"night_ask_at\", 0);\nvar leaveUntil = g(\"night_leave_until\", 0);\n\nif (!jeNoc || isLocked(lock)) {\n    if (askAt) s(\"night_ask_at\", 0);\n    if (leaveUntil) s(\"night_leave_until\", 0);   // pri zamceni nebo ve dne zrus 'nechat'\n} else if (!nikdoDoma && isUnlocked(lock) && doorClosed) {\n    if (now < leaveUntil) {\n        node.status({ fill: \"grey\", shape: \"ring\", text: \"Noc: necham (znovu za \" + Math.round((leaveUntil - now) / 60000) + \" min)\" });\n        return null;\n    }\n    if (askAt === 0) {\n        s(\"night_ask_at\", now);\n        msg.payload = {\n            title: \"Nocni kontrola zamku\",\n            message: \"Je po 21:00 a hlavni dvere jsou odemcene. Mam zamknout?\",\n            data: {\n                tag: \"nocni_zamek\",\n                actions: [\n                    { action: \"LOCK_NOW\", title: \"Zamkni ted\" },\n                    { action: \"LEAVE_UNLOCKED\", title: \"Nech to na mě\" }\n                ]\n            }\n        };\n        node.status({ fill: \"blue\", shape: \"dot\", text: \"Noc: ptam se (zamknout?)\" });\n        return [null, null, msg];\n    }\n    if (now - askAt >= ASK_TIMEOUT_MS) {\n        s(\"night_ask_at\", 0);\n        s(\"pending_action\", \"lock\");\n        s(\"last_cmd_at\", now);\n        node.status({ fill: \"yellow\", shape: \"dot\", text: \"Noc: bez reakce -> ZAMYKAM\" });\n        return [msg, null, null];\n    }\n    node.status({ fill: \"blue\", shape: \"ring\", text: \"Noc: cekam na reakci (\" + Math.round((now - askAt) / 60000) + \"/3 min)\" });\n    return null;\n}\n\nif (maBytZamceno && isLocked(lock)) {\n    node.status({ fill: \"yellow\", shape: \"dot\", text: \"OK zamceno door=\" + (door || \"?\") });\n} else if (!maBytZamceno && isUnlocked(lock)) {\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK doma/den\" });\n} else {\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK lock=\" + lock + \" door=\" + (door || \"?\") });\n}\nreturn null;",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
