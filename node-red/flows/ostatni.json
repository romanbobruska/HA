    {
        "id": "lock_notif_func",
        "type": "function",
        "z": "58f453ee71c85d6d",
        "g": "314bb66109910b71",
        "name": "Sestav notifikaci",
        "func": "// Notifikace na telefon pri zmene stavu zamku hlavnich dveri.\nvar st = msg.payload;\nvar text = \"\";\nif (st === \"locked\") { text = \"Hlavni dvere byly zamceny.\"; }\nelse if (st === \"unlocked\") { text = \"Hlavni dvere byly odemceny.\"; }\nelse if (st === \"jammed\") { text = \"Pozor: zamek hlavnich dveri hlasi zaseknuti.\"; }\nelse { return null; }\nmsg.payload = { title: \"Hlavni dvere\", message: text };\nreturn msg;\n",
