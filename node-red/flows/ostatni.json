        "g": "314bb66109910b71",
        "name": "Reakce na akci notifikace",
        "func": "// Reakce na akcni notifikaci nocniho zamku (event mobile_app_notification_action)\n// KONFLIKT-PRAVIDLO: ZAMKNI je dominantni. Kdyz jeden da NECHAT a druhy ZAMKNI\n// (i behem nekolika sekund), plati ZAMKNUTI. Druhy clen si odemkne rucne.\nvar LEAVE_MS = 3600000;      // -> zeptat znovu\nvar DOMINANCE_MS = 15000;    // okno, kdy ZAMKNI prebije pozdejsi NECHAT (soubeh)\nvar p = msg.payload || {};\nvar action = p.action || (p.event && p.event.action) || (msg.data && msg.data.action) || \"\";\nvar now = Date.now();\nfunction g(k, def){ var v = global.get(\"lock_\" + k); if (v === undefined) v = flow.get(\"lock_\" + k); return (v === undefined || v === null) ? def : v; }\nfunction s(k, v){ global.set(\"lock_\" + k, v); flow.set(\"lock_\" + k, v); }\nif (action === \"LOCK_NOW\") {\n    s(\"dominant_until\", now + DOMINANCE_MS);   // ZAMKNI vyhrava nad NECHAT\n    s(\"night_ask_at\", 0);\n    s(\"night_leave_until\", 0);\n    node.status({ fill: \"yellow\", shape: \"dot\", text: \"Akce: ZAMKNI ihned (dominant)\" });\n    return msg;            // -> Zamkni dum\n}\nif (action === \"LEAVE_UNLOCKED\") {\n    if (now < g(\"dominant_until\", 0)) {        // nekdo prave dal ZAMKNI -> ignoruj NECHAT\n        node.status({ fill: \"yellow\", shape: \"ring\", text: \"NECHAT ignorovano (ZAMKNI vyhral)\" });\n        return null;\n    }\n    s(\"night_leave_until\", now + LEAVE_MS);\n    s(\"night_ask_at\", 0);\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"Akce: nechat, znovu za \" + Math.round(LEAVE_MS / 60000) + \" min\" });\n    return null;\n}\nreturn null;",
