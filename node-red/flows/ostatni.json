    {
        "id": "lock_eval_func",
        "type": "function",
        "z": "58f453ee71c85d6d",
        "g": "314bb66109910b71",
        "name": "Vyhodnoť stav zámku",
        "func": "// Zamek hlavni dvere (Yale Linus L2) — rizeni stavu vs pravidla.\n// PRAVIDLA:\n//   ODEMKNI: jen na HRANU vstupu sekce_1 do \"disarmed\" (prijezd domu). Jinak NIKDY neodemyka.\n//   ZAMKNI : kdyz ma byt zamceno (sekce_1 armed* OR garaz armed* OR noc 23-06) a neni zamceno.\n//   JINAK  : NIC (idempotence) — jeden prikaz na prechod => zadny Google Home spam.\n//   Rucni vstup ma prioritu (odemykame jen na hranu prijezdu; rucni odemceni v noci/armed = 1h hold).\n// out1 = ZAMKNI (lock.lock), out2 = ODEMKNI (lock.unlock)\n\nvar LOCK_ID  = \"lock.hlavni_dvere\";\nvar CELK_ID  = \"alarm_control_panel.horousany_sekce_1_celkovy_alarm\";\nvar GARAZ_ID = \"alarm_control_panel.horousany_sekce_7_garaz_alarm\";\nvar NIGHT_FROM = 23, NIGHT_TO = 6;\nvar COOLDOWN_MS = 10000;                  // po vlastnim prikazu klid (anti-spam)\nvar MANUAL_UNLOCK_HOLD_MS = 60 * 60 * 1000; // rucni odemceni v dobe \"ma byt zamceno\" -> hold\n\nfunction gS(id){ return (global.get(\"homeassistant.homeAssistant.states['\" + id + \"']\") || {}).state || \"\"; }\nfunction isArmed(x){ return x && x.indexOf(\"armed\") === 0; }\nfunction isLocked(st){ return st === \"locked\" || st === \"locking\"; }\nfunction isUnlocked(st){ return st === \"unlocked\" || st === \"unlocking\" || st === \"open\"; }\nfunction g(k, def){ var v = global.get(\"lock_\" + k); if (v === undefined) v = flow.get(\"lock_\" + k); return (v === undefined || v === null) ? def : v; }\nfunction s(k, v){ global.set(\"lock_\" + k, v); flow.set(\"lock_\" + k, v); }\n\nvar celk = gS(CELK_ID);\nvar garaz = gS(GARAZ_ID);\nvar lock = gS(LOCK_ID);\nvar h = new Date().getHours();\nvar now = Date.now();\n\nif (!lock || lock === \"unavailable\" || lock === \"unknown\") {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"lock nedostupny: \" + (lock || \"?\") });\n    return null;\n}\n\nvar jeNoc = (h >= NIGHT_FROM || h < NIGHT_TO);\nvar maBytZamceno = isArmed(celk) || isArmed(garaz) || jeNoc;\n\nvar lastCmdAt = g(\"last_cmd_at\", 0);\nvar pending = g(\"pending_action\", null);\nvar lastObs = g(\"last_observed\", undefined);\nvar prevCelk = g(\"prev_celk\", undefined);\nvar manualUntil = g(\"manual_unlock_until\", 0);\n\n// Potvrzeni pending z realneho stavu\nif (pending === \"lock\" && isLocked(lock)) { pending = null; s(\"pending_action\", null); }\nif (pending === \"unlock\" && isUnlocked(lock)) { pending = null; s(\"pending_action\", null); }\n\n// Detekce rucni zmeny zamku (zmena, kterou jsme nezpusobili my)\nif (lastObs !== undefined && lock !== lastObs && (now - lastCmdAt) > 5000) {\n    if (isUnlocked(lock) && maBytZamceno) {\n        manualUntil = now + MANUAL_UNLOCK_HOLD_MS; // rucni odemceni v dobe \"ma byt zamceno\"\n        s(\"manual_unlock_until\", manualUntil);\n    }\n    pending = null; s(\"pending_action\", null);\n}\ns(\"last_observed\", lock);\n\n// HRANA prijezdu: sekce_1 vstoupila do \"disarmed\" z jineho stavu\nvar disarmEdge = (prevCelk !== undefined && prevCelk !== \"disarmed\" && celk === \"disarmed\");\ns(\"prev_celk\", celk);\n\n// Cooldown po vlastnim prikazu\nif (now - lastCmdAt < COOLDOWN_MS) {\n    node.status({ fill: \"grey\", shape: \"ring\", text: \"cooldown lock=\" + lock });\n    return null;\n}\n\n// === ODEMKNI — jen na hranu prijezdu, jen kdyz je zamceno, jednou ===\nif (disarmEdge && isLocked(lock)) {\n    if (pending === \"unlock\") { return null; }\n    s(\"pending_action\", \"unlock\");\n    s(\"last_cmd_at\", now);\n    s(\"manual_unlock_until\", 0);\n    node.status({ fill: \"green\", shape: \"dot\", text: \"ODEMYKAM (prijezd) lock=\" + lock });\n    return [null, msg];\n}\n\n// === ZAMKNI — kdyz ma byt zamceno a neni, jednou (respekt k rucnimu odemceni) ===\nif (maBytZamceno && !isLocked(lock)) {\n    if (now < manualUntil) {\n        var minLeft = Math.ceil((manualUntil - now) / 60000);\n        node.status({ fill: \"blue\", shape: \"ring\", text: \"rucni odemceno, hold \" + minLeft + \"min\" });\n        return null;\n    }\n    if (pending === \"lock\") { return null; }\n    s(\"pending_action\", \"lock\");\n    s(\"last_cmd_at\", now);\n    node.status({ fill: \"yellow\", shape: \"dot\", text: \"ZAMYKAM lock=\" + lock });\n    return [msg, null];\n}\n\n// === Stav odpovida pravidlum — NIC ===\nif (maBytZamceno && isLocked(lock)) {\n    node.status({ fill: \"yellow\", shape: \"dot\", text: \"OK zamceno\" });\n} else {\n    node.status({ fill: \"green\", shape: \"dot\", text: \"OK (disarmed/den) lock=\" + lock });\n}\nreturn null;\n",
        "outputs": 2,
