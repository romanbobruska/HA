        "g": "314bb66109910b71",
        "name": "Vyhodnoť stav zámku",
        "func": "// Vyhodnoceni stavu zamku — agreguje 3 podminky a posila lock/unlock idempotentne.\n// Pravidlo (uzivatel 10.5.2026):\n//   ZAMCENO pokud: celkAlarm armed* OR garazAlarm armed* OR (cas v okne 23:00-06:00)\n//   ODEMCENO pokud: VSECHNY 3 podminky FALSE\n//   Idempotence: pokud je zamek uz ve spravnem stavu, neposila nic (predchazi spam volani lock.lock/unlock\n//                a nedeterministicke vyhrani prikazu pri kolizi).\nvar s = global.get(\"homeassistant.homeAssistant.states\") || {};\nfunction gS(id) { return ((s[id]||{}).state) || \"\"; }\nfunction isArmed(x) { return x && x.indexOf(\"armed\") === 0; }\nvar celk  = gS(\"alarm_control_panel.horousany_sekce_1_celkovy_alarm\");\nvar garaz = gS(\"alarm_control_panel.horousany_sekce_7_garaz_alarm\");\nvar lock  = gS(\"lock.yale_chytry_zamek\");\nvar h = new Date().getHours();\nvar jeNoc = (h >= 23 || h < 6); // 23:00-06:00\nvar maBytZamceno = isArmed(celk) || isArmed(garaz) || jeNoc;\nvar reason = (isArmed(celk) ? \"celk(\"+celk+\")\" : \"\")\n    + (isArmed(garaz) ? \" garaz(\"+garaz+\")\" : \"\")\n    + (jeNoc ? \" noc\" : \"\");\nnode.status({fill: maBytZamceno ? \"yellow\" : \"green\", shape: \"dot\",\n    text: (maBytZamceno?\"ZAM\":\"ODEM\") + \" lock=\"+lock+\" \"+(reason||\"vse off\")});\nif (maBytZamceno && lock !== \"locked\") return [msg, null];\nif (!maBytZamceno && lock === \"locked\") return [null, msg];\nreturn null; // zadna zmena\n",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
