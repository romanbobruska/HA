        "g": "09797f9996ff875a",
        "name": "🧠 Rozhodovací logika",
        "func": "// 🧠 Rozhodovací logika bojleru — cílová teplota dle přebytku, ceny, forecastu\n\n// === KONFIGURACE (z flow kontextu) ===\nvar teplotaMax = flow.get(\"TEPLOTA_MAX\") || 69, teplotaVysoka = flow.get(\"TEPLOTA_VYSOKA\") || 60, teplotaStredni = flow.get(\"TEPLOTA_STREDNI\") || 55;\nvar teplotaMin = flow.get(\"TEPLOTA_MIN\") || 20, teplotaPovinnySolar = flow.get(\"TEPLOTA_POVINNY_SOLAR\") || 40;\nvar hystereze = flow.get(\"HYSTEREZE\") || 500, spotrebaBojler = flow.get(\"SPOTREBA_BOJLER\") || 2500;\nvar priceLevelLevny = flow.get(\"PRICE_LEVEL_LEVNY\") || 3, cenaKwhLevna = flow.get(\"CENA_KWH_LEVNA\") || 2.6;\nvar forecastThreshold = flow.get(\"FORECAST_THRESHOLD\") || 35000;\n\n// === GLOBÁLNÍ STAV ===\nvar maxSpotrebaSit = global.get(\"max_spotreba_sit\") || 24000, forecastDnes = global.get(\"forecast_vyroba_dnes\") || 0, forecastZitra = global.get(\"forecast_vyroba_zitra\") || 0;\nvar cerpadloTopi = global.get(\"cerpadlo_topi\") === true;\nvar climateEntity = global.get(\"homeassistant.homeAssistant.states['climate.smart_socket_thermostat_24090276694597600801c4e7ae0a2e53']\") || {};\nvar aktualniTeplota = parseFloat((climateEntity.attributes || {}).temperature) || 0;\nvar cfg = global.get(\"fve_config\") || {}, maxGrid = cfg.max_spotreba_sit_w || 22000, safetyMargin = cfg.safety_margin_w || 2000, sitLimit = maxGrid - safetyMargin;\n\n// === VSTUPY Z MSG ===\nvar jsmeDoma = msg.jsme_doma === \"on\", rychleVoda = msg.rychle_voda === \"on\", teplotaBojleru = msg.teplota_bojleru || 0;\nvar spotrebaBojleruAkt = msg.spotreba_bojleru || 0, batteryPercent = msg.battery_percent || 0, rozdilVyroby = msg.rozdil_vyroby || 0;\nvar letniRezim = msg.letni_rezim === \"on\", autoHlad = msg.auto_hlad === \"on\", autoAutomatizace = msg.auto_automatizace === \"on\";\nvar priceLevel = msg.price_level || 24, cenaKwh = msg.cena_kwh || 10, celkovaSpotreba = msg.celkova_spotreba || 0, spotrebaZeSite = msg.spotreba_ze_site || 0;\n\n// === ČASOVÉ PODMÍNKY ===\nvar hour = new Date().getHours(), minute = new Date().getMinutes(), currentMinute = hour * 60 + minute;\nvar jePovinnyOhrevCas = currentMinute >= 17 * 60 && currentMinute <= 19 * 60 + 30, bojlerZapnut = spotrebaBojleruAkt > 100, volnaKapacita = sitLimit - celkovaSpotreba, maZalohu = bojlerZapnut || (volnaKapacita >= spotrebaBojler);\n\n// === PRAHY PŘEBYTKU ===\nvar prahZapMax = 4000 + spotrebaBojler + hystereze, prahVelkyMax = 4000, prahZapVysoka = spotrebaBojler + hystereze, prahVypVysoka = -hystereze;\n\n// === CENOVÉ + FORECAST PODMÍNKY ===\nvar jeLevnaEnergie = (priceLevel <= priceLevelLevny) || (cenaKwh <= cenaKwhLevna), solarniDenDnes = forecastDnes > forecastThreshold, solarniDenZitra = forecastZitra > forecastThreshold;\n\n// === ROZHODOVÁNÍ ===\nvar cilovaTeplota = teplotaMin, duvod = \"\";\n\nif (!jsmeDoma) {\n    cilovaTeplota = teplotaMin;\n    duvod = \"Není doma\";\n}\nelse if (rychleVoda) {\n    cilovaTeplota = teplotaMax;\n    duvod = \"Rychle voda\";\n}\n// --- Povinný čas 17:00-19:30 ---\nelse if (jePovinnyOhrevCas && teplotaBojleru < 58) {\n    if (!maZalohu) {\n        cilovaTeplota = teplotaMin;\n        duvod = \"Pov.čas limit sítě\";\n    }\n    else if (solarniDenZitra && teplotaBojleru >= teplotaPovinnySolar) {\n        cilovaTeplota = teplotaPovinnySolar;\n        duvod = \"Pov.čas zítra sol→\" + teplotaPovinnySolar + \"°C\";\n    }\n    else if (solarniDenZitra) {\n        cilovaTeplota = teplotaPovinnySolar;\n        duvod = \"Pov.ohřev na \" + teplotaPovinnySolar + \"°C\";\n    }\n    else {\n        cilovaTeplota = teplotaVysoka;\n        duvod = \"Pov.ohřev 17-19:30\";\n    }\n}\n// --- NIBE kompresor běží a nízký přebytek ---\nelse if (cerpadloTopi && rozdilVyroby < prahZapVysoka) {\n    cilovaTeplota = teplotaMin;\n    duvod = \"NIBE přeb:\" + Math.round(rozdilVyroby / 1000) + \"kW\";\n}\n// --- Baterie > 96% ---\nelse if (batteryPercent > 96) {\n    var prahMax = bojlerZapnut ? prahVelkyMax : prahZapMax, prahVysoka = bojlerZapnut ? prahVypVysoka : prahZapVysoka;\n    if (rozdilVyroby > prahMax) {\n        cilovaTeplota = autoHlad && autoAutomatizace ? teplotaVysoka : teplotaMax;\n        duvod = (autoHlad ? \"Přeb+auto\" : \"Bat plné+přeb \") + (Math.round(rozdilVyroby / 1000)) + \"kW\";\n    }\n    else if (rozdilVyroby > prahVysoka) {\n        cilovaTeplota = teplotaVysoka;\n        duvod = \"Přeb \" + Math.round(rozdilVyroby / 1000) + \"kW\";\n    }\n    else if (bojlerZapnut && rozdilVyroby > -spotrebaBojler) {\n        cilovaTeplota = flow.get(\"posledni_cilova_teplota\") || teplotaMin;\n        duvod = \"Hystereze \" + cilovaTeplota + \"°C\";\n    }\n    else {\n        if (!letniRezim && jeLevnaEnergie && maZalohu) {\n            cilovaTeplota = teplotaStredni;\n            duvod = \"Levná L\" + priceLevel;\n        } else {\n            cilovaTeplota = teplotaMin;\n            duvod = letniRezim ? \"Léto čeká\" : \"Drahá/málo\";\n        }\n    }\n}\n// --- Běžný stav (baterie <= 96%) ---\nelse {\n    var prahVysokaBat = bojlerZapnut ? prahVypVysoka : prahZapVysoka, prahMaxBat = bojlerZapnut ? prahVelkyMax : prahZapMax;\n    if (rozdilVyroby > prahMaxBat) {\n        cilovaTeplota = teplotaMax;\n        duvod = \"Velký přeb \" + Math.round(rozdilVyroby / 1000) + \"kW bat:\" + batteryPercent + \"%\";\n    }\n    else if (rozdilVyroby > prahVysokaBat) {\n        cilovaTeplota = teplotaVysoka;\n        duvod = \"Přeb \" + Math.round(rozdilVyroby / 1000) + \"kW bat:\" + batteryPercent + \"%\";\n    }\n    else if (bojlerZapnut && rozdilVyroby > -spotrebaBojler) {\n        cilovaTeplota = flow.get(\"posledni_cilova_teplota\") || teplotaMin;\n        duvod = \"Hystereze \" + cilovaTeplota + \"°C\";\n    }\n    else if (letniRezim && solarniDenDnes) {\n        cilovaTeplota = teplotaMin;\n        duvod = \"Léto fc:\" + Math.round(forecastDnes / 1000) + \"kWh\";\n    }\n    else if (!letniRezim && jeLevnaEnergie && maZalohu) {\n        cilovaTeplota = teplotaStredni;\n        duvod = \"Levná L\" + priceLevel + \" \" + cenaKwh + \"Kč\";\n    }\n    else {\n        cilovaTeplota = teplotaMin;\n        duvod = letniRezim ? \"Léto solar\" : !maZalohu ? \"Limit sítě\" : \"Drahá\";\n    }\n}\n\n// === VÝSTUP ===\nflow.set(\"posledni_cilova_teplota\", cilovaTeplota);\n\nvar climateState = (climateEntity || {}).state || \"unavailable\";\nif (climateState === \"unavailable\") { node.status({fill: \"red\", shape: \"ring\", text: \"Meross UNAVAIL\"}); return null; }\nif (cilovaTeplota === aktualniTeplota) { node.status({fill: \"blue\", shape: \"dot\", text: cilovaTeplota + \"/\" + aktualniTeplota + \"°C BEZ ZMĚNY \" + duvod}); return null; }\n\nmsg.payload = {teplota: cilovaTeplota, duvod: duvod, debug: {dom: jsmeDoma, rv: rychleVoda, tB: teplotaBojleru, bat: batteryPercent, rV: rozdilVyroby, let2: letniRezim, pL: priceLevel, cK: cenaKwh, jLE: jeLevnaEnergie, cS: celkovaSpotreba, mZ: maZalohu}};\nvar barva = \"grey\"; if (cilovaTeplota >= teplotaVysoka) barva = \"green\"; else if (cilovaTeplota >= teplotaStredni) barva = \"yellow\";\nnode.status({fill: barva, shape: bojlerZapnut ? \"ring\" : \"dot\", text: cilovaTeplota + \"°C \" + duvod});\nreturn msg;\n",
