    {
        "id": "7efc2560d20a0a05",
        "type": "function",
        "z": "0a2df88897520187",
        "g": "7d6c1cd0300cfd29",
        "name": "📝 Nastav parametry",
        "func": "// ╔════════════════════════════════════════════════════════════╗\n// ║  KONFIGUROVATELNÉ PARAMETRY - UPRAV HODNOTY N֦E           ║\n// ╚════════════════════════════════════════════════════════════╝\n\nconst CONFIG = {\n    // === TEPLOTY (°C) ===\n    TEPLOTA_MAX: 69,        // Maximální teplota bojleru\n    TEPLOTA_VYSOKA: 60,     // Vysoká teplota (bاný ohřev)\n    TEPLOTA_STREDNI: 58,    // Střední teplota (levná elektřina)\n    TEPLOTA_MIN: 20,        // Minimální teplota (vypnuto)\n    TEPLOTA_POVINNY_SOLAR: 40, // Teplota v povinných hodinách když zítra velký solár\n    \n    // === HYSTEREZE A SPOTŘEBA ===\n    HYSTEREZE: 500,         // Hystereze v W (zabraňuje oscilaci)\n    SPOTREBA_BOJLER: 2500,  // Spotřeba bojleru v W\n    \n    // === CENOVÉ PRAHY ===\n    PRICE_LEVEL_LEVNY: 6,   // Level ceny (1-24), kdy je proud levný\n    CENA_KWH_LEVNA: 2.6,    // Cena v Kč/kWh, kdy je proud levný\n    \n    // === FORECAST ===\n    FORECAST_THRESHOLD: 35000  // Práh forecastu v Wh (35kWh)\n};\n\n// ╔════════════════════════════════════════════════════════════╗\n// ║  ULOŽENÍ DO FLOW PROMĚNNÝCH - NEMĚNIT                      ║\n// ╚════════════════════════════════════════════════════════════╝\n\nfor (const [key, value] of Object.entries(CONFIG)) {\n    flow.set(key, value);\n}\n\nmsg.payload = {\n    status: \"Konfigurace uložena\",\n    config: CONFIG\n};\n\nnode.status({fill: \"green\", shape: \"dot\", text: \"Konfigurace uložena\"});\n//node.warn(\"Bojler konfigurace uložena: \" + JSON.stringify(CONFIG));\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 80,
