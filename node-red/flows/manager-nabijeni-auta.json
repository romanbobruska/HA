    {
        "id": "probe_decision_func",
        "type": "function",
        "z": "7ceb7c5337692ae5",
        "g": "probe_grp",
        "name": "Probe Decision",
        "func": "// Auto Hunger Probe — zjištění skutečného stavu auta při připojení\n// Řeší: state 6 (WaitStart) nerozlišuje nabité vs hladové auto\n// Trigger: state change z obou wallboxů\n// Outputs: [1] start probe | [2] hlad ON | [3] hlad OFF\n\nvar entityId = msg.topic || \"\";\nvar isGarage = entityId === \"sensor.charger_state_garage\";\nvar newState = parseInt(msg.payload) || 0;\nvar oldState = (msg.data && msg.data.old_state) ? parseInt(msg.data.old_state.state) || 0 : 0;\n\nif (isGarage) {\n    // === GARÁŽ — probe při prvním připojení ===\n    if (newState === 0) {\n        // Odpojeno → žádný hlad\n        flow.set(\"probe_active\", false);\n        flow.set(\"garage_hunger\", false);\n        node.status({fill: \"grey\", shape: \"ring\", text: \"Garáž: odpojeno\"});\n    }\n    else if (newState === 3) {\n        // Nabité → žádný hlad\n        flow.set(\"probe_active\", false);\n        flow.set(\"garage_hunger\", false);\n        node.status({fill: \"green\", shape: \"dot\", text: \"Garáž: nabité\"});\n    }\n    else if (newState === 2) {\n        // Nabíjí se → má hlad\n        flow.set(\"garage_hunger\", true);\n        node.status({fill: \"blue\", shape: \"dot\", text: \"Garáž: nabíjí se\"});\n    }\n    else if (oldState === 0 && newState !== 0) {\n        // Auto právě připojeno → spustit probe\n        flow.set(\"probe_active\", true);\n        flow.set(\"garage_hunger\", true); // bezpečný default\n        node.status({fill: \"yellow\", shape: \"dot\", text: \"Garáž: probe spuštěn...\"});\n        // Out1: start probe sekvenci, Out2: hlad ON (safe default)\n        return [msg, msg, null];\n    }\n} else {\n    // === VENKOVNÍ WALLBOX — bez probe (zachováno staré chování) ===\n    if (newState === 0 || newState === 3) {\n        flow.set(\"outdoor_hunger\", false);\n    } else if (newState === 2 || newState === 4 || newState === 6) {\n        flow.set(\"outdoor_hunger\", true);\n    }\n}\n\n// Vyhodnoť kombinovaný hlad (garáž OR venkovní)\nvar garageHunger = flow.get(\"garage_hunger\") || false;\nvar outdoorHunger = flow.get(\"outdoor_hunger\") || false;\n\nif (garageHunger || outdoorHunger) {\n    return [null, msg, null]; // Out2: hlad ON\n} else {\n    return [null, null, msg]; // Out3: hlad OFF\n}\n",
