    {
        "id": "probe_result_func",
        "type": "function",
        "z": "7ceb7c5337692ae5",
        "g": "probe_grp",
        "name": "Probe Result",
        "func": "// Probe Read Result — čtení stavu chargeru po 20s delay\n// Outputs: [1] hlad ON | [2] hlad OFF | [3] charger OFF (vždy po probe)\n\n// Kontrola, zda probe nebyl mezitím zrušen (např. auto odpojeno)\nif (!flow.get(\"probe_active\")) {\n    node.status({fill: \"grey\", shape: \"ring\", text: \"Probe zrušen\"});\n    return [null, null, msg]; // jen vypni charger pro jistotu\n}\nflow.set(\"probe_active\", false);\n\nvar chargerState = parseInt(\n    (global.get(\"homeassistant.homeAssistant.states['sensor.charger_state_garage']\") || {}).state\n) || 0;\n\nvar outdoorHunger = flow.get(\"outdoor_hunger\") || false;\n\nif (chargerState === 3) {\n    // Auto je nabité → garage nemá hlad\n    flow.set(\"garage_hunger\", false);\n    node.status({fill: \"green\", shape: \"dot\", text: \"Probe: nabité (st.3)\"});\n    if (outdoorHunger) {\n        return [msg, null, msg]; // venkovní má hlad → celkově ON\n    }\n    return [null, msg, msg]; // žádný hlad → OFF\n} else {\n    // Auto má hlad (st.2) nebo jiný stav\n    flow.set(\"garage_hunger\", true);\n    node.status({fill: \"red\", shape: \"dot\", text: \"Probe: hlad (st.\" + chargerState + \")\"});\n    return [msg, null, msg]; // hlad ON + charger OFF\n}\n",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 480,
        "wires": [
