    {
        "id": "main_logic_func",
        "type": "function",
        "z": "7ceb7c5337692ae5",
        "g": "mgr_grp_logic",
        "name": "Rozhodovací logika v2.7",
        "func": "// Manager nabíjení auta v24.2 — [1]stop [2]slunce [3]síť\nfunction gS(id){return(global.get(\"homeassistant.homeAssistant.states['\"+id+\"']\")||{}).state;}\nfunction gB(id){return gS(id)===\"on\";}\nfunction gF(id,d){var v=parseFloat(gS(id));return isNaN(v)?(d||0):v;}\nvar cfg=global.get(\"fve_config\")||{};\n// Skip during hunger probe (charger is temporarily ON for state detection)\nif(flow.get(\"probe_active\")){node.status({fill:\"yellow\",shape:\"ring\",text:\"Probe probíhá...\"});return null;}\nvar hlad=gB(\"input_boolean.auto_ma_hlad\"),auto=gB(\"input_boolean.automatizovat_nabijeni_auta\");\nvar solRez=gB(\"input_boolean.solarni_rezim_nabijeni_auta\"),letni=gB(\"input_boolean.letni_rezim\");\nvar solCyklus=gB(\"input_boolean.nastavuj_amperaci_chargeru_solar\");\nvar chSt=gS(\"sensor.charger_state_garage\")||\"0\";\nvar src=(cfg.solar_forecast_source||\"VICTRON\").toUpperCase();\nvar eD=src===\"OPEN_METEO\"?\"sensor.energy_production_today_3\":\"input_number.predpoved_solarni_vyroby_dnes\";\nvar eZ=src===\"OPEN_METEO\"?\"sensor.energy_production_tomorrow_3\":\"input_number.predpoved_solarni_vyroby_zitra\";\nvar vD=gF(eD,0),vZ=gF(eZ,0),soc=gF(\"sensor.battery_percent\",0),roz=gF(\"sensor.rozdil_vyroby_a_spotreby\",0);\nvar FK=cfg.nabijeni_auta_forecast_kwh||40,MS=cfg.nabijeni_auta_solar_w||4000,MSS=cfg.nabijeni_auta_min_soc_slunce||85;\nfunction stop(t){global.set(\"balancing_solar_car\",false);node.status({fill:\"grey\",shape:\"ring\",text:t});return[[msg],null,null];}\nfunction slunce(t,c){global.set(\"balancing_solar_car\",!!c);node.status({fill:\"green\",shape:\"dot\",text:t});return[null,[msg],null];}\n// Law 5.0: auto OFF = do NOTHING (before any other check!)\nif(!auto){node.status({fill:\"grey\",shape:\"ring\",text:\"Auto OFF\\u2192NIC\"});return null;}\nif(!hlad)return stop(\"Nemá hlad\");\n// Balancování\nvar fpa=(global.get(\"homeassistant.homeAssistant.states['sensor.fve_plan']\")||{}).attributes||{};\nvar bal=fpa.current_mode===\"Balancování\";\nif(!bal&&global.get(\"balancing_active\"))global.set(\"balancing_active\",false);\nif(bal){if(soc<99)return stop(\"⚡Bal SOC:\"+soc+\"%\");\nif(solCyklus)return slunce(\"⚡☀Bal+cyklus SOC:\"+soc+\"%\",true);\nvar BR=cfg.balancing_grid_reserve_w||1000,BMS=6*3*230+BR;\nif(roz>BMS)return slunce(\"⚡☀Bal+start přeb:\"+Math.round(roz)+\"W\",true);\nreturn stop(\"⚡Bal žádný přebytek\");}\nglobal.set(\"balancing_solar_car\",false);\nif(soc<MSS)return stop(\"SOC \"+soc+\"%<\"+MSS+\"%\");\nif(solCyklus){node.status({fill:\"green\",shape:\"dot\",text:\"☀Cyklus SOC:\"+soc+\"% přeb:\"+Math.round(roz)+\"W ch:\"+chSt});return[null,[msg],null];}\nvar curSol=gF(\"sensor.vyroba_fve\",0),chActive=chSt===\"2\";\nif(chActive&&curSol>MS&&!solCyklus)return slunce(\"☀Takeover sol:\"+Math.round(curSol)+\"W\",false);\nvar bSD=global.get(\"balancing_solar_dump\")||false;\nif(bSD&&curSol>MS)return slunce(\"⚡SolDump sol:\"+Math.round(curSol)+\"W\",false);\nvar avail=gF(\"sensor.fve_dostupny_prebytek\",0),maPreb=avail>MS;\nif(solRez&&maPreb){node.status({fill:\"green\",shape:\"dot\",text:\"Solar ON přeb:\"+Math.round(avail)+\"W\"});return[null,[msg],null];}\nif(letni&&maPreb){node.status({fill:\"green\",shape:\"dot\",text:\"Letní přeb:\"+Math.round(avail)+\"W\"});return[null,[msg],null];}\nif(vD>FK&&maPreb){node.status({fill:\"green\",shape:\"dot\",text:\"Dnes \"+Math.round(vD)+\"kWh+přeb\"});return[null,[msg],null];}\nif(vZ>FK&&maPreb){node.status({fill:\"green\",shape:\"dot\",text:\"Zítra \"+Math.round(vZ)+\"kWh+přeb\"});return[null,[msg],null];}\nif(vZ>FK||vD>FK){node.status({fill:\"orange\",shape:\"ring\",text:\"Čeká přeb dnes:\"+Math.round(vD)+\" zítra:\"+Math.round(vZ)});return[[msg],null,null];}\nnode.status({fill:\"blue\",shape:\"dot\",text:\"Síť dnes:\"+Math.round(vD)+\" zítra:\"+Math.round(vZ)+\" soc:\"+soc+\"%\"});\nreturn[null,null,[msg]];\n",
        "outputs": 3,
