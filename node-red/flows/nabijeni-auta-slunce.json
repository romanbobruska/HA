    {
        "id": "788e188fae8d1fca",
        "type": "function",
        "z": "49921d17efb0cefe",
        "g": "68ded079ca35f344",
        "name": "Vypočítej max amperaci v2",
        "func": "// Korekční smyčka nabíjení auta ze slunce v4 — clean rewrite per laws 5.0, 5.1\nvar spotrSit=msg.payload_spotreba||0,soc=msg.payload_battpct;\nvar cfg=global.get(\"fve_config\")||{};\n\n// Cooldown 15s (prevents overlapping chain)\nvar now=Date.now(),lastRun=global.get(\"solar_corr_last_run\")||0;\nif(now-lastRun<4000)return null;\nglobal.set(\"solar_corr_last_run\",now);\n\n// LAW 5.0: Automation OFF → do NOTHING (applies to solar AND grid)\nvar autoS=global.get(\"homeassistant.homeAssistant.states['input_boolean.automatizovat_nabijeni_auta']\")||{};\nif(autoS.state!==\"on\"){node.status({fill:\"grey\",shape:\"ring\",text:\"Auto OFF\"});return null;}\n\n// Config\nvar MSS=cfg.nabijeni_auta_min_soc_slunce||85;\nvar SDT=cfg.nabijeni_auta_soc_drain_prah||95;\nvar SDW=cfg.nabijeni_auta_soc_drain_w||1500;\nvar TBW=cfg.nabijeni_auta_target_batt_w||1000;\nvar DB=cfg.nabijeni_auta_dead_band_w||500;\nvar GRID_MAX=cfg.nabijeni_auta_max_grid_w||200;\nvar BR=cfg.balancing_grid_reserve_w||1000;\n\n// Read states\nvar aS=global.get(\"homeassistant.homeAssistant.states['select.wallboxu_garaz_amperace']\")||{};\nvar curA=parseInt(String(aS.state||\"0\").replace(/[^0-9]/g,\"\"),10)||0;\nvar bMinus=msg.payload_batt_minus||0,rozW=msg.payload;\nvar bS=global.get(\"homeassistant.homeAssistant.states['sensor.nabijeni_baterii']\")||{};\nvar bW=parseFloat(bS.state)||0;\nvar gS=global.get(\"homeassistant.homeAssistant.states['sensor.spotreba_ze_site']\")||{};\nvar gridW=parseFloat(gS.state)||0;\n\n// LAW 5.1: SOC < MSS → stop (0A)\nif(soc<MSS){node.status({fill:\"red\",shape:\"ring\",text:\"SOC \"+soc+\"%<\"+MSS+\"%→0A\"});msg.payload=0;return msg;}\n\nvar hi=soc>=99;\nvar drain=soc>=SDT;\nvar gMax=GRID_MAX;\n\n// === CHARGER RUNNING (curA >= 6) — feedback ±1A per cycle (law 5.1) ===\nif(curA>=6){\n  var tA=curA,zone=\"\";\n  // HIGHEST PRIORITY: grid draw > threshold → -1A (law 5.1: NIKDY ze sítě)\n  if(gridW>gMax){\n    tA=curA-1;\n    zone=\"GRID:\"+Math.round(gridW)+\"W>\"+gMax+\"W\";\n  }\n  // DRAIN (SOC>=95%): range-based — battery MUST discharge (law 5.1)\n  else if(drain){\n    zone=\"DRAIN\";\n    var MAX_DR=cfg.nabijeni_auta_max_drain_w||2500;\n    if(bW>300)tA=curA+1;\n    else if(bW<-MAX_DR)tA=curA-1;\n    // -MAX_DR <= bW <= 300 → stable (battery discharging within range)\n  }\n  // CHR (SOC 85-95%): range-based — battery must charge, but not too much\n  else{\n    zone=\"CHRG\";\n    var MAX_CHR=cfg.nabijeni_auta_max_charge_w||2000;\n    if(bW<0)tA=curA-1;\n    else if(bW>MAX_CHR&&gridW<gMax/2)tA=curA+1;\n    // 0 <= bW <= MAX_CHR → stable (battery charging within range)\n  }\n  // Clamp: 6-16A or 0A\n  if(tA<6)tA=0;\n  if(tA>16)tA=16;\n  node.status({fill:tA>0?\"green\":\"red\",shape:\"dot\",\n    text:tA+\"A(\"+zone+\" b:\"+Math.round(bW)+\"W g:\"+Math.round(gridW)+\"W n:\"+curA+\"A SOC:\"+soc+\"%)\"});\n  msg.payload=tA;return msg;\n}\n\n// === STARTUP (charger not running) — conservative initial amperage ===\nvar curW=curA*3*230;\nvar avW=rozW+curW;\nif(hi)avW-=BR;\nelse if(soc>=MSS&&!drain){\n  var SCW=cfg.nabijeni_auta_soc_charge_w||1000;\n  avW-=SCW;if(bMinus>50)avW-=bMinus;\n}else if(drain)avW+=SDW;\n\nvar tA2=Math.floor(avW/690);\nif(tA2>16)tA2=16;\nif(tA2<6)tA2=0;\nnode.status({fill:tA2>0?\"green\":\"red\",shape:\"dot\",\n  text:tA2+\"A(START av:\"+Math.round(avW)+\"W g:\"+Math.round(gridW)+\"W SOC:\"+soc+\"%)\"});\nmsg.payload=tA2;return msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 962,
        "y": 660,
        "wires": [
            [
                "82f8a5c6cfa6c254"
            ]
        ]
