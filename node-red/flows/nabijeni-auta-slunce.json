        "name": "Baterky > min_soc_slunce?",
        "func": "var config = global.get('fve_config') || {};\nvar prah = config.nabijeni_auta_min_soc_slunce || 85;\nvar stav = global.get(\"homeassistant.homeAssistant.states['sensor.battery_percent']\") || {};\nvar soc = parseFloat(stav.state);\nif (isNaN(soc)) { node.status({fill:'red',shape:'ring',text:'SOC NaN'}); return [null, msg]; }\nnode.status({fill: soc > prah ? 'green' : 'yellow', shape:'dot', text: soc + '% (prah ' + prah + '%)'});\nif (soc > prah) { return [msg, null]; }\nreturn [null, msg];",
