    {
        "id": "788e188fae8d1fca",
        "type": "function",
        "z": "49921d17efb0cefe",
        "g": "68ded079ca35f344",
        "name": "Vypočítej max amperaci v2",
        "func": "// Vypočítej max amperaci v3 — anti-oscillation fix\nvar spotrSit=msg.payload_spotreba||0,soc=msg.payload_battpct;\nvar cfg=global.get(\"fve_config\")||{};\n// Cooldown: skip if last run < 15s ago (prevents overlapping chain execution)\nvar now=Date.now(),lastRun=global.get(\"solar_corr_last_run\")||0;\nif(now-lastRun<15000){return null;}\nglobal.set(\"solar_corr_last_run\",now);\n// Read current wallbox state\nvar aS=global.get(\"homeassistant.homeAssistant.states['select.wallboxu_garaz_amperace']\")||{};\nvar rawA=String(aS.state||'0'),curA=parseInt(rawA.replace(/[^0-9]/g,''),10)||0,curW=curA*3*230;\nvar bMinus=msg.payload_batt_minus||0,rozW=msg.payload;\nvar hi=soc>=99,BR=cfg.balancing_grid_reserve_w||1000;\nvar MSS=cfg.nabijeni_auta_min_soc_slunce||85,SDT=cfg.nabijeni_auta_soc_drain_prah||95,SDW=cfg.nabijeni_auta_soc_drain_w||1000;\nvar MAX_STEP=cfg.nabijeni_auta_max_step||2,GRID_MAX=cfg.nabijeni_auta_max_grid_w||200;\n// SOC too low → stop\nif(soc<MSS){node.status({fill:'red',shape:'ring',text:'SOC '+soc+'%<'+MSS+'%→0A'});msg.payload=0;return msg;}\n// Read battery charging power\nvar bS=global.get(\"homeassistant.homeAssistant.states['sensor.nabijeni_baterii']\")||{};\nvar bW=parseFloat(bS.state)||0;\n// Read grid consumption\nvar gS=global.get(\"homeassistant.homeAssistant.states['sensor.spotreba_ze_site']\")||{};\nvar gridW=parseFloat(gS.state)||0;\nvar tA=curA;\n// GRID DRAW SAFETY — highest priority (relaxed in DRAIN mode for phase imbalance)\nvar gMax=(soc>=SDT)?(cfg.nabijeni_auta_max_grid_drain_w||500):GRID_MAX;\nif(gridW>gMax&&curA>=6){\nvar drop=Math.max(1,Math.ceil((gridW-GRID_MAX)/690));\ntA=curA-drop;\nif(tA<6)tA=0;\nnode.status({fill:'red',shape:'dot',text:tA+'A(GRID:'+Math.round(gridW)+'W>'+gMax+'W drop:'+drop+')'});\nmsg.payload=tA;return msg;}\n// BATTERY DISCHARGE SAFETY — battery must not drain during solar charging (law 5.1)\nif(soc<SDT&&bW<0&&curA>=6){\nvar TBW0=cfg.nabijeni_auta_target_batt_w||1000;\nvar bDrop=Math.max(1,Math.ceil((-bW+TBW0)/690));\ntA=curA-bDrop;\nif(tA<6)tA=0;\nnode.status({fill:'red',shape:'dot',text:tA+'A(BATT:'+Math.round(bW)+'W<0 drop:'+bDrop+')'})\nmsg.payload=tA;return msg;}\n// CHARGER RUNNING — feedback-based control (±1A per cycle)\nif(curA>=6){var zone='';\nif(soc>=SDT){zone='DRAIN';\nif(bW<-SDW)tA=curA-1;\nelse if(bW>1500||(hi&&rozW>500))tA=curA+1;}\nelse{var TBW=cfg.nabijeni_auta_target_batt_w||1000,DB=cfg.nabijeni_auta_dead_band_w||500;\nzone='CHRG t='+TBW;\nif(bW>TBW+DB)tA=curA+1;\nelse if(bW<TBW-DB)tA=curA-1;}\n// Rate limit\nif(tA>curA+MAX_STEP)tA=curA+MAX_STEP;\nif(tA<curA-MAX_STEP)tA=curA-MAX_STEP;\nif(tA<6)tA=0;if(tA>16)tA=16;\nnode.status({fill:'green',shape:'dot',text:tA+'A(FB b:'+Math.round(bW)+'W g:'+Math.round(gridW)+'W n:'+curA+'A SOC:'+soc+'% '+zone+')'});\nmsg.payload=tA;return msg;}\n// STARTUP — charger not running yet, calculate initial amperage conservatively\nvar avW=rozW+curW;\nif(hi){avW-=BR;}\nelse{var SCW=cfg.nabijeni_auta_soc_charge_w||1000;\nif(soc>=MSS&&soc<SDT){avW-=SCW;if(bMinus>50)avW-=bMinus;}\nelse if(soc>=SDT){avW+=SDW;}}\nvar tA2=Math.floor(avW/230/3);\n// Rate limit startup too — max +2A from current (or start at 6A)\nif(curA>0){if(tA2>curA+MAX_STEP)tA2=curA+MAX_STEP;if(tA2<curA-MAX_STEP)tA2=curA-MAX_STEP;}\nif(tA2>16)tA2=16;\nif(tA2<6&&avW>-1000)tA2=6;else if(tA2<6)tA2=0;\nnode.status({fill:tA2>0?'green':'red',shape:'dot',text:tA2+'A(START av:'+Math.round(avW)+'W g:'+Math.round(gridW)+'W SOC:'+soc+'%)'});\nmsg.payload=tA2;return msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 962,
